# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/streamvault"

# Paystack
PAYSTACK_SECRET_KEY="your-paystack-secret-key"
PAYSTACK_PUBLIC_KEY="your-paystack-public-key"
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="your-paystack-public-key"

# Currency (NGN, USD, GHS, ZAR, etc.)
NEXT_PUBLIC_CURRENCY="NGN"
NEXT_PUBLIC_CURRENCY_SYMBOL="₦"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# Admin
ADMIN_PASSWORD="change-this-strong-password"
ADMIN_JWT_SECRET="change-this-jwt-secret-min-32-chars"

# Token signing
TOKEN_SECRET="change-this-token-secret-min-32-chars"

# Cloudflare Stream
# Account ID: Cloudflare Dashboard → right sidebar
CF_ACCOUNT_ID="your-cloudflare-account-id"
# API Token: Cloudflare Dashboard → My Profile → API Tokens → Create Token (Stream:Edit)
CF_STREAM_API_TOKEN="your-cloudflare-stream-api-token"
# Signing Key: Cloudflare Stream Dashboard → Signing Keys → Generate
CF_STREAM_KEY_ID="your-signing-key-id"
# Private key PEM — paste the full key, replacing newlines with \n
CF_STREAM_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEow...\n-----END RSA PRIVATE KEY-----"
# Customer code: found in any CF Stream playback URL
# e.g. https://customer-XXXXXX.cloudflarestream.com/...
CF_CUSTOMER_CODE="your-customer-subdomain-code"
